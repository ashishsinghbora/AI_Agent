# Environment Configuration for Research Agent
# Copy to .env and configure with your values

# Ollama Configuration
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_PRIMARY_MODEL=deepseek-r1:7b
OLLAMA_FALLBACK_MODEL=gemma2:2b

# Web Research APIs (Optional)
TAVILY_API_KEY=your_api_key_here
DUCKDUCKGO_SAFE_SEARCH=moderate

# Vector Store
CHROMA_PERSIST_DIR=/tmp/chroma

# Research Notes Directory
RESEARCH_NOTES_PATH=/home/ashu/research_notes

# FastAPI Configuration
FASTAPI_HOST=0.0.0.0
FASTAPI_PORT=8000
FASTAPI_RELOAD=true

# Frontend Configuration
REACT_APP_API_BASE_URL=http://localhost:8000
REACT_APP_WS_URL=ws://localhost:8000
